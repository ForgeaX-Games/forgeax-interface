{
  "name": "@forgeax/design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ForgeaX/ForgeaX design system SSOT — design tokens (CSS) + Tailwind preset + theme helpers. React-free. Imported by the host (interface) and every plugin so they share one visual language without sharing a component bundle.",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./preset": "./preset.ts",
    "./theme": "./theme.ts",
    "./tokens.css": "./tokens.css",
    "./styles/primitive.css": "./styles/primitive.css",
    "./styles/semantic.css": "./styles/semantic.css",
    "./styles/fx-bridge.css": "./styles/fx-bridge.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "peerDependenciesMeta": {
    "tailwindcss": { "optional": true },
    "tailwindcss-animate": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
