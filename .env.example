# Aegis (Galileo) front-end monitoring — copy to `.env.local` (gitignored) and
# fill in real values. With these unset the monitoring code is a no-op, so this
# file ships safe placeholders only (no internal hostnames).
#
# Monitoring is active ONLY in a production build (`bun run build`/`preview`,
# deployed web, or the desktop .app) AND when VITE_AEGIS_ID is set. `bun dev`
# stays silent by design.
#
# VITE_AEGIS_ID    — project token registered on the Galileo platform.
# VITE_AEGIS_SDK_URL  — versioned Aegis V2 SDK script url.
# VITE_AEGIS_HOST_URL — Galileo collect endpoint.
# VITE_AEGIS_ENV   — optional; defaults to "production".
# VITE_AEGIS_TRACE_URLS — optional; comma-separated regex sources for URLs to
#                    inject the `traceparent` header into (front↔back trace
#                    linking). Defaults to same-origin /api + /ws.
# VITE_AEGIS_DEV   — optional; '1' makes `bun dev` report too (off by default,
#                    so dev stays silent). Pair with VITE_AEGIS_ENV=test.
# VITE_AEGIS_CONSOLE_LEVELS — optional; console.* levels mirrored to Galileo as
#                    logs (comma-sep). Default all (log,info,warn,error,debug);
#                    "off" disables; "warn,error" to cut volume.
# VITE_AEGIS_DELAY — optional; report aggregation window in ms (reports within it
#                    merge into one request). Default 5000 (SDK default 1000).

VITE_AEGIS_ID=
VITE_AEGIS_SDK_URL=
VITE_AEGIS_HOST_URL=
VITE_AEGIS_ENV=production
VITE_AEGIS_TRACE_URLS=
