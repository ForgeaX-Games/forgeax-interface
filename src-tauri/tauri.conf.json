{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "ForgeaX Studio",
  "version": "0.3.7",
  "identifier": "com.forgeax.studio",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:18920",
    "beforeBuildCommand": "",
    "frontendDist": "../../studio/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ForgeaX Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/bun"
    ],
    "resources": [
      "resources"
    ]
  },
  "plugins": {}
}
